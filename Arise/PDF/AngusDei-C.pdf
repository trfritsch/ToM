<script>
(function() {
	var trigger = document.querySelector('[data-lang-picker-trigger]');
	var menu = document.querySelector('[data-lang-picker-menu]');
	if(!trigger || !menu) return;

	// Render flag emoji as inline SVG images via Twemoji so they
	// display correctly on Chrome/Windows (which doesn't support
	// country flag emoji natively in Segoe UI Emoji).
	if(typeof twemoji !== 'undefined') {
		var flags = document.querySelectorAll('.lang-picker-flag');
		for(var i = 0; i < flags.length; i++) {
			twemoji.parse(flags[i], {
				base: 'https://cdn.jsdelivr.net/gh/twitter/twemoji@14.0.2/assets/',
				folder: 'svg',
				ext: '.svg'
			});
		}
	}

	function closeMenu() {
		menu.setAttribute('hidden', '');
		trigger.setAttribute('aria-expanded', 'false');
	}
	function openMenu() {
		var rect = trigger.getBoundingClientRect();
		var isRTL = document.documentElement.dir === 'rtl';
		// Reset both sides so the previous position doesn't interfere.
		menu.style.left = '';
		menu.style.right = '';
		menu.style.top = (rect.bottom + 8) + 'px';
		if(isRTL) {
			// In RTL the trigger is on the left — anchor the menu's
			// left edge to the trigger's left edge.
			menu.style.left = rect.left + 'px';
		} else {
			// In LTR the trigger is on the right — anchor the menu's
			// right edge to the trigger's right edge.
			menu.style.right = (window.innerWidth - rect.right) + 'px';
		}
		menu.removeAttribute('hidden');
		trigger.setAttribute('aria-expanded', 'true');
	}
	trigger.addEventListener('click', function(e) {
		e.preventDefault();
		e.stopPropagation();
		if(menu.hasAttribute('hidden')) openMenu();
		else closeMenu();
	});
	document.addEventListener('click', function(e) {
		if(trigger.contains(e.target) || menu.contains(e.target)) return;
		closeMenu();
	});
	document.addEventListener('keydown', function(e) {
		if(e.key === 'Escape') closeMenu();
	});
	window.addEventListener('resize', closeMenu);
	// Close on page scroll, but ignore scroll events that originate
	// inside the menu itself — otherwise scrolling the menu dismisses it.
	window.addEventListener('scroll', function(e) {
		if(e.target && menu.contains(e.target)) return;
		closeMenu();
	}, true);
})();
</script>
